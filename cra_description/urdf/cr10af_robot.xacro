<?xml version="1.0"?>
<robot name="cr10af_robot" xmlns:xacro="http://ros.org/wiki/xacro">
  <link name="dummy_link"/>
  <link
    name="base_link">
    <inertial>
      <origin
        xyz="-3.7612E-06 0.0011357 0.032382"
        rpy="0 0 0" />
      <mass
        value="2.01" />
      <inertia
        ixx="0.0042064"
        ixy="6.3817E-07"
        ixz="4.917E-07"
        iyy="0.0040224"
        iyz="1.8082E-05"
        izz="0.0067707" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find cra_description)/meshes/cr10af/base_link.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.59216 0.59216 0.59216 1" />
      </material>
    </visual>
    <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="file://$(find cra_description)/meshes/cr10af/base_link.STL" />
      </geometry>
    </collision>
  </link>
    <link  name="world"/>
<joint name="world_joint" type="fixed">
    <origin xyz="0 0 0.03" rpy="0 0 0" />
    <parent link="world" />
    <child  link="dummy_link" />
  </joint>
  <joint name="dummy_joint" type="fixed">
      <parent link="dummy_link" />
      <child  link="base_link" />
    </joint>
  <link
